PORT=3005
DATABASE_URL=postgresql://user:password@localhost:5432/palcli

# Public URL of this API (no trailing slash). Used by Better Auth and OAuth callbacks.
BETTER_AUTH_URL=http://localhost:3005
# Or use API_PUBLIC_URL as an alias for the same value.

# Comma-separated browser origins allowed to use cookies / CORS with this API.
TRUSTED_ORIGINS=http://localhost:3000

# Next.js app URL (device-flow redirect after /device on the server).
CLIENT_APP_URL=http://localhost:3000

# Optional additional CORS origin. Use exact origin without trailing slash.
CORS_ORIGIN=http://localhost:3000

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional override; defaults to ${BETTER_AUTH_URL}/api/auth/callback/github
# GITHUB_REDIRECT_URI=

# Google Generative AI (server-side chat).
GOOGLE_GENERATIVE_AI_API_KEY=
PALCLI_MODEL=gemini-2.5-flash
